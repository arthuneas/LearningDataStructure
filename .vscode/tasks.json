{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compilar meu programa em C",
            "type": "shell",
            "command": "C:\\mingw64\\bin\\gcc.exe",
            "args": [
                "-Wall",
                "-Wextra",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\output\\${fileBasenameNoExtension}.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "focus": true
            },
            "problemMatcher": "$gcc"
        }
    ]
}